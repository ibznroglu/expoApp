{
  "statusLine": {
    "type": "command",
    "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const w=j.context_window_size||0;const u=j.context_tokens_used||0;if(w)process.stdout.write('ctx '+Math.round(u/w*100)+'%')}catch(e){}})\""
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm start)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
