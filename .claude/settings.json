{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm start)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
